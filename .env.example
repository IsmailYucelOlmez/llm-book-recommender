# Required: Google Gemini API key (embeddings + query rewriting)
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key

# Optional but recommended: Google Books API key.
# Without it, the Google Books API still works but with a much lower quota,
# which can cause silent rate-limit errors under load in the "Advanced" search mode.
# Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_BOOKS_API_KEY=your-google-books-api-key
